{
  "expo": {
    "name": "Safar",
    "slug": "safar-mobile",
    "scheme": "masjidly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "app.masjidly",
      "supportsTablet": true,
      "associatedDomains": [
        "applinks:masjidly.app"
      ],
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Safar uses your location to show nearby masjids and sort events by distance.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "6"
    },
    "android": {
      "package": "app.masjidly",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "masjidly.app",
              "pathPrefix": "/event/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-notifications",
      "expo-secure-store",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Safar uses your location to show nearby masjids and sort events by distance."
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "4079faa0-1fc1-45f7-bfea-6b2e2b7a68a7"
      }
    },
    "owner": "ss4108",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/4079faa0-1fc1-45f7-bfea-6b2e2b7a68a7"
    }
  }
}
